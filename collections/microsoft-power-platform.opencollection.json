        },
        {
          "info": {
            "name": "Get metadata for a specific table by logical name",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://{org}.api.crm.dynamics.com/api/data/v9.2/EntityDefinitions(LogicalName=':logicalName')",
